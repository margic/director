{
  "name": "director",
  "version": "0.0.7",
  "description": "Sim RaceCenter Director UI App",
  "main": "dist-electron/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && tsc -p tsconfig.main.json && node scripts/copy-extension-assets.js && node run-electron.js\"",
    "build": "tsc -p tsconfig.main.json && node scripts/copy-extension-assets.js && vite build",
    "generate-icons": "electron-icon-builder --input=./assets/images/icon-logo.png --output=build --flatten",
    "dist": "npm run generate-icons && npm run build && electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:director-loop": "ts-node --transpile-only -P tsconfig.test.json -r tsconfig-paths/register scripts/test-director-loop.ts"
  },
  "build": {
    "appId": "com.simracecenter.director",
    "productName": "Sim RaceCenter Director",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      {
        "from": "build/icons/512x512.png",
        "to": "icon.png"
      },
      "!.env"
    ],
    "extraResources": [
      ".env"
    ],
    "icon": "build/icons/512x512.png",
    "win": {
      "target": "nsis",
      "icon": "build/icons/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icons"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/margic/director.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/margic/director/issues"
  },
  "homepage": "https://github.com/margic/director#readme",
  "dependencies": {
    "@azure/msal-node": "^3.8.4",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.18.0",
    "applicationinsights": "^3.12.1",
    "clsx": "^2.1.1",
    "discord-tts": "^1.2.2",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.3",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^8.1.0",
    "ffmpeg-static": "^5.3.0",
    "googleapis": "^170.0.0",
    "koffi": "^2.15.0",
    "libsodium-wrappers": "^0.8.0",
    "lucide-react": "^0.562.0",
    "obs-websocket-js": "^5.0.7",
    "opusscript": "^0.0.8",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "electron-icon-builder": "^2.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "wait-on": "^9.0.3"
  },
  "overrides": {
    "form-data": "^2.5.2",
    "qs": "^6.14.1",
    "tough-cookie": "^4.1.3",
    "phin": "^3.7.1"
  }
}
