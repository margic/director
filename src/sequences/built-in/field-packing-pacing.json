{
  "id": "seq_field_packing_pacing",
  "name": "Field Packing Pacing",
  "version": "1.0.0",
  "description": "Slow panoramic cuts to show the entire field bunching up behind the pace car.",
  "category": "builtin",
  "priority": false,
  "variables": [
    { "name": "targetDriver", "label": "Driver Car Number", "type": "text", "required": true, "source": "cloud" },
    { "name": "durationMs", "label": "Wait Duration", "type": "number", "required": true, "source": "cloud" }
  ],
  "steps": [
    { "id": "step_1", "intent": "obs.switchScene", "payload": { "sceneName": "Director Solo" } },
    { "id": "step_2", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "18" } },
    { "id": "step_3", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 10000, "maxMs": 18000 }, "narrativePurpose": "establish" } },
    { "id": "step_4", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "10" } },
    { "id": "step_5", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 10000, "maxMs": 18000 }, "narrativePurpose": "build" } },
    { "id": "step_6", "intent": "obs.switchScene", "payload": { "sceneName": "Rig 1 Solo" } },
    { "id": "step_7", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 7000, "maxMs": 12000 }, "narrativePurpose": "action" } },
    { "id": "step_8", "intent": "obs.switchScene", "payload": { "sceneName": "Director Solo" } },
    { "id": "step_9", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "15" } },
    { "id": "step_10", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 8000, "maxMs": 14000 }, "narrativePurpose": "resolve" } }
  ],
  "metadata": {
    "source": "ai-planner",
    "applicability": "Used during full-course yellow laps while the field packs behind the pace car.",
    "racePhase": "caution",
    "durationRange": { "min": 35000, "max": 60000 }
  }
}
