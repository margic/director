{
  "id": "seq_scenic_pacing",
  "name": "Scenic Pacing",
  "version": "1.0.0",
  "description": "Atmospheric, slow-paced template highlighting track beauty and isolation.",
  "category": "builtin",
  "priority": false,
  "variables": [
    { "name": "targetDriver", "label": "Driver Car Number", "type": "text", "required": true, "source": "cloud" },
    { "name": "durationMs", "label": "Wait Duration", "type": "number", "required": true, "source": "cloud" }
  ],
  "steps": [
    { "id": "step_1", "intent": "obs.switchScene", "payload": { "sceneName": "Director Solo" } },
    { "id": "step_2", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "10" } },
    { "id": "step_3", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 12000, "maxMs": 20000 }, "narrativePurpose": "establish" } },
    { "id": "step_4", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "18" } },
    { "id": "step_5", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 12000, "maxMs": 20000 }, "narrativePurpose": "build" } },
    { "id": "step_6", "intent": "obs.switchScene", "payload": { "sceneName": "Rig 1 Solo" } },
    { "id": "step_7", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 10000, "maxMs": 15000 }, "narrativePurpose": "action" } },
    { "id": "step_8", "intent": "obs.switchScene", "payload": { "sceneName": "Director Solo" } },
    { "id": "step_9", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "21" } },
    { "id": "step_10", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 10000, "maxMs": 15000 }, "narrativePurpose": "resolve" } }
  ],
  "metadata": {
    "source": "ai-planner",
    "applicability": "Use during very quiet periods of a long race to show environmental context.",
    "racePhase": "rhythm",
    "durationRange": { "min": 45000, "max": 70000 }
  }
}
