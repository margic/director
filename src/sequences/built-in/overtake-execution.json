{
  "id": "seq_overtake_execution",
  "name": "Overtake Execution",
  "version": "1.0.0",
  "description": "Fast-paced coverage meant for a high-probability overtake. Heavy reliance on TV tracking cams mixed with onboard.",
  "category": "builtin",
  "priority": false,
  "variables": [
    { "name": "targetDriver", "label": "Driver Car Number", "type": "text", "required": true, "source": "cloud" },
    { "name": "durationMs", "label": "Wait Duration", "type": "number", "required": true, "source": "cloud" }
  ],
  "steps": [
    { "id": "step_1", "intent": "obs.switchScene", "payload": { "sceneName": "Director Solo" } },
    { "id": "step_2", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "12" } },
    { "id": "step_3", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 4000, "maxMs": 7000, "paceModifier": "compress-on-action" }, "narrativePurpose": "establish" } },
    { "id": "step_4", "intent": "obs.switchScene", "payload": { "sceneName": "Rig 1 Solo" } },
    { "id": "step_5", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 4000, "maxMs": 7000, "paceModifier": "compress-on-action" }, "narrativePurpose": "build" } },
    { "id": "step_6", "intent": "obs.switchScene", "payload": { "sceneName": "Director Solo" } },
    { "id": "step_7", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "11" } },
    { "id": "step_8", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 5000, "maxMs": 8000, "paceModifier": "compress-on-action" }, "narrativePurpose": "action" } },
    { "id": "step_9", "intent": "obs.switchScene", "payload": { "sceneName": "Rig 1 Solo" } },
    { "id": "step_10", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 4000, "maxMs": 7000 }, "narrativePurpose": "reaction" } },
    { "id": "step_11", "intent": "obs.switchScene", "payload": { "sceneName": "Director Solo" } },
    { "id": "step_12", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "20" } },
    { "id": "step_13", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 5000, "maxMs": 9000 }, "narrativePurpose": "resolve" } }
  ],
  "metadata": {
    "source": "ai-planner",
    "applicability": "When telemetry predicts an immediate pass (gap < 0.5s).",
    "racePhase": "action",
    "durationRange": { "min": 25000, "max": 40000 }
  }
}
