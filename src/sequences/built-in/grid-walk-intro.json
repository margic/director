{
  "id": "seq_grid_walk_intro",
  "name": "Grid Walk Intro",
  "version": "1.0.0",
  "description": "Pre-race grid walk starting with a scenic wide shot, moving to our driver's onboard, and finishing with a nose camera inspection.",
  "category": "builtin",
  "priority": false,
  "variables": [
    {
      "name": "targetDriver",
      "label": "Driver Car Number",
      "type": "text",
      "required": true,
      "source": "cloud"
    },
    {
      "name": "durationMs",
      "label": "Wait Duration",
      "type": "number",
      "required": true,
      "source": "cloud"
    }
  ],
  "steps": [
    { "id": "step_1", "intent": "obs.switchScene", "payload": { "sceneName": "Director Solo" } },
    { "id": "step_2", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "10" } },
    { "id": "step_3", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 10000, "maxMs": 15000, "paceModifier": "stretch-on-caution" }, "narrativePurpose": "establish" } },
    { "id": "step_4", "intent": "obs.switchScene", "payload": { "sceneName": "Rig 1 Solo" } },
    { "id": "step_5", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 8000, "maxMs": 12000 }, "narrativePurpose": "build" } },
    { "id": "step_6", "intent": "obs.switchScene", "payload": { "sceneName": "Director Solo" } },
    { "id": "step_7", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "1" } },
    { "id": "step_8", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 6000, "maxMs": 10000 }, "narrativePurpose": "action" } },
    { "id": "step_9", "intent": "obs.switchScene", "payload": { "sceneName": "Rig 1 Solo" } },
    { "id": "step_10", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 6000, "maxMs": 8000 }, "narrativePurpose": "resolve" } }
  ],
  "metadata": {
    "source": "ai-planner",
    "applicability": "Use during the pre-grid phase to introduce a SimRaceCenter driver while showing the track atmosphere.",
    "racePhase": "pre-green",
    "durationRange": { "min": 30000, "max": 45000 }
  }
}
