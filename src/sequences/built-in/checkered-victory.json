{
  "id": "seq_checkered_victory",
  "name": "Checkered Victory",
  "version": "1.0.0",
  "description": "The finish — TTS celebration, then a cinematic sequence to mark the end of the race.",
  "category": "builtin",
  "priority": false,
  "variables": [
    { "name": "targetDriver", "label": "Driver Car Number", "type": "text", "required": true, "source": "cloud" },
    { "name": "durationMs", "label": "Wait Duration", "type": "number", "required": true, "source": "cloud" },
    { "name": "ttsMessage", "label": "Finish Announcement", "type": "text", "required": true, "source": "cloud" }
  ],
  "steps": [
    { "id": "step_1", "intent": "communication.announce", "payload": { "message": "${ttsMessage}" } },
    { "id": "step_2", "intent": "obs.switchScene", "payload": { "sceneName": "Director Solo" } },
    { "id": "step_3", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "11" } },
    { "id": "step_4", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 10000, "maxMs": 18000 }, "narrativePurpose": "establish" } },
    { "id": "step_5", "intent": "obs.switchScene", "payload": { "sceneName": "Rig 1 Solo" } },
    { "id": "step_6", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 10000, "maxMs": 18000 }, "narrativePurpose": "build" } },
    { "id": "step_7", "intent": "obs.switchScene", "payload": { "sceneName": "Director Solo" } },
    { "id": "step_8", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "10" } },
    { "id": "step_9", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 15000, "maxMs": 24000 }, "narrativePurpose": "resolve" } }
  ],
  "metadata": {
    "source": "ai-planner",
    "applicability": "Plays once the checkered flag wave is confirmed for our driver.",
    "racePhase": "closing",
    "durationRange": { "min": 35000, "max": 60000 }
  }
}
