{
  "id": "seq_incident_direct_reaction",
  "name": "Incident Direct Reaction",
  "version": "1.0.0",
  "description": "Immediate reaction to a nearby incident. Wide shot shows the scene then cuts to our driver's reaction onboard.",
  "category": "builtin",
  "priority": true,
  "variables": [
    { "name": "targetDriver", "label": "Driver Car Number", "type": "text", "required": true, "source": "cloud" },
    { "name": "durationMs", "label": "Wait Duration", "type": "number", "required": true, "source": "cloud" }
  ],
  "steps": [
    { "id": "step_1", "intent": "obs.switchScene", "payload": { "sceneName": "Director Solo" } },
    { "id": "step_2", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "11" } },
    { "id": "step_3", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 5000, "maxMs": 8000, "paceModifier": "compress-on-action" }, "narrativePurpose": "establish" } },
    { "id": "step_4", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "12" } },
    { "id": "step_5", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 5000, "maxMs": 8000, "paceModifier": "compress-on-action" }, "narrativePurpose": "build" } },
    { "id": "step_6", "intent": "obs.switchScene", "payload": { "sceneName": "Rig 1 Solo" } },
    { "id": "step_7", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 5000, "maxMs": 9000 }, "narrativePurpose": "reaction" } },
    { "id": "step_8", "intent": "obs.switchScene", "payload": { "sceneName": "Director Solo" } },
    { "id": "step_9", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "20" } },
    { "id": "step_10", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 6000, "maxMs": 11000 }, "narrativePurpose": "resolve" } }
  ],
  "metadata": {
    "source": "ai-planner",
    "applicability": "Triggered immediately when an incident flag is raised near our driver.",
    "racePhase": "caution",
    "durationRange": { "min": 25000, "max": 40000 }
  }
}
