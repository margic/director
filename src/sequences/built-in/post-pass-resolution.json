{
  "id": "seq_post_pass_resolution",
  "name": "Post-Pass Resolution",
  "version": "1.0.0",
  "description": "Shows the outcome immediately after a position change, verifying the gap and driver reaction.",
  "category": "builtin",
  "priority": false,
  "variables": [
    { "name": "targetDriver", "label": "Driver Car Number", "type": "text", "required": true, "source": "cloud" },
    { "name": "durationMs", "label": "Wait Duration", "type": "number", "required": true, "source": "cloud" }
  ],
  "steps": [
    { "id": "step_1", "intent": "obs.switchScene", "payload": { "sceneName": "Rig 1 Solo" } },
    { "id": "step_2", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 6000, "maxMs": 10000 }, "narrativePurpose": "establish" } },
    { "id": "step_3", "intent": "obs.switchScene", "payload": { "sceneName": "Director Solo" } },
    { "id": "step_4", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "11" } },
    { "id": "step_5", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 5000, "maxMs": 8000 }, "narrativePurpose": "build" } },
    { "id": "step_6", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "22" } },
    { "id": "step_7", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 6000, "maxMs": 9000 }, "narrativePurpose": "action" } },
    { "id": "step_8", "intent": "obs.switchScene", "payload": { "sceneName": "Rig 1 Solo" } },
    { "id": "step_9", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 5000, "maxMs": 8000 }, "narrativePurpose": "resolve" } }
  ],
  "metadata": {
    "source": "ai-planner",
    "applicability": "Triggered right after an overtake finishes to solidify the narrative.",
    "racePhase": "action",
    "durationRange": { "min": 25000, "max": 35000 }
  }
}
