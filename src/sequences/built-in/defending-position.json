{
  "id": "seq_defending_position",
  "name": "Defending Position",
  "version": "1.0.0",
  "description": "Highlights our driver under attack by starting with a rear chase cam to show the pursuer, cutting to the defensive onboard.",
  "category": "builtin",
  "priority": false,
  "variables": [
    { "name": "targetDriver", "label": "Driver Car Number", "type": "text", "required": true, "source": "cloud" },
    { "name": "durationMs", "label": "Wait Duration", "type": "number", "required": true, "source": "cloud" }
  ],
  "steps": [
    { "id": "step_1", "intent": "obs.switchScene", "payload": { "sceneName": "Director Solo" } },
    { "id": "step_2", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "22" } },
    { "id": "step_3", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 6000, "maxMs": 11000, "paceModifier": "compress-on-action" }, "narrativePurpose": "establish" } },
    { "id": "step_4", "intent": "obs.switchScene", "payload": { "sceneName": "Rig 1 Solo" } },
    { "id": "step_5", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 6000, "maxMs": 9000 }, "narrativePurpose": "build" } },
    { "id": "step_6", "intent": "obs.switchScene", "payload": { "sceneName": "Director Solo" } },
    { "id": "step_7", "intent": "broadcast.showLiveCam", "payload": { "carNum": "${targetDriver}", "camGroup": "12" } },
    { "id": "step_8", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 5000, "maxMs": 8000, "paceModifier": "compress-on-action" }, "narrativePurpose": "action" } },
    { "id": "step_9", "intent": "obs.switchScene", "payload": { "sceneName": "Rig 1 Solo" } },
    { "id": "step_10", "intent": "system.wait", "payload": { "durationMs": "${durationMs}" }, "metadata": { "holdHint": { "minMs": 5000, "maxMs": 10000 }, "narrativePurpose": "resolve" } }
  ],
  "metadata": {
    "source": "ai-planner",
    "applicability": "Ideal when our driver has a shrinking gap to the car behind.",
    "racePhase": "action",
    "durationRange": { "min": 25000, "max": 40000 }
  }
}
